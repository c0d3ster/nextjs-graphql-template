{
  "template": {
    "name": "Next.js GraphQL Template",
    "version": "1.0.0",
    "description": "A modern Next.js template with GraphQL, TypeScript, and authentication"
  },
  "variables": {
    "project": {
      "name": "{{PROJECT_NAME}}",
      "description": "{{PROJECT_DESCRIPTION}}",
      "author": "{{AUTHOR_NAME}}",
      "email": "{{AUTHOR_EMAIL}}",
      "githubUsername": "{{GITHUB_USERNAME}}"
    },
    "branding": {
      "companyName": "{{COMPANY_NAME}}",
      "supportEmail": "{{SUPPORT_EMAIL}}",
      "websiteUrl": "{{WEBSITE_URL}}",
      "logoPath": "{{LOGO_PATH}}",
      "linkedinUsername": "{{LINKEDIN_USERNAME}}"
    },
    "features": {
      "portfolio": true,
      "projectManagement": true,
      "contactForm": true,
      "authentication": true,
      "fileUpload": true,
      "dashboard": true
    }
  },
  "files": {
    "replace": [
      "package.json",
      "README.md",
      "src/constants/brand.ts",
      "src/app/layout.tsx",
      "src/app/(public)/page.tsx",
      "src/app/(public)/layout.tsx"
    ],
    "remove": [
      "src/app/(public)/ballz/",
      "src/app/(public)/projects/",
      "src/components/organisms/landing-sections/",
      "src/components/molecules/project-card/",
      "src/components/molecules/project-request/",
      "src/components/molecules/project-status/"
    ]
  }
}
